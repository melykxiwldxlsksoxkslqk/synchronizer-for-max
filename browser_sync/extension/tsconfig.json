{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "noEmitOnError": true,
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": [
    "src/content-main.ts",
    "src/content/**/*.ts"
  ]
}

